{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BASE_API_URL": "https://pageturner-backend-o1h8.onrender.com/api/v1/"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BASE_API_URL": "https://pageturner-backend-o1h8.onrender.com/api/v1/"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
